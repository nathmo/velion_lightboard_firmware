 // ═══════════════════════════════════════════════════════════════════
 //  SOFTWARE TIMERS
 // ═══════════════════════════════════════════════════════════════════
 struct SoftTimer {
   bool     running;
   uint32_t startMs;
   uint32_t durationMs;
 };
 
 void timerStart(SoftTimer &t, uint32_t ms) {
   t.running    = true;
   t.startMs    = millis();
   t.durationMs = ms;
 }
 
 void timerStop(SoftTimer &t) { t.running = false; }
 
 bool timerExpired(SoftTimer &t) {
   if (!t.running) return false;
   if (millis() - t.startMs >= t.durationMs) {
     t.running = false;
     return true;
   }
   return false;
 }
 
